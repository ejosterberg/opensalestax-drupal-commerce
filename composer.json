{
    "name": "ejosterberg/opensalestax-drupal-commerce",
    "description": "Drupal Commerce 3.x tax type plugin that calculates destination-based US sales tax via a self-hosted OpenSalesTax engine.",
    "type": "drupal-module",
    "license": "Apache-2.0",
    "keywords": [
        "drupal",
        "drupal-commerce",
        "tax",
        "sales-tax",
        "us-tax",
        "opensalestax"
    ],
    "homepage": "https://github.com/ejosterberg/opensalestax-drupal-commerce",
    "authors": [
        {
            "name": "Eric Osterberg",
            "email": "ejosterberg@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ejosterberg/opensalestax": "^0.1",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Drupal\\opensalestax_commerce\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Drupal\\Tests\\opensalestax_commerce\\": "tests/src/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --no-progress",
        "audit": "@composer audit"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
